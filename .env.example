VITE_APP_URL=https://ton-app.vercel.app

# Supabase Edge Functions Secrets (configurer dans Supabase Dashboard → Edge Functions → Secrets)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=notifications@votredomaine.com
# ONESIGNAL_API_KEY=os_v2_app_xxxxxxxxxxxxxxxxxxxxxxxx

