# SUPABASE_ANON_KEY=          (même valeur que VITE_SUPABASE_ANON_KEY)
# SUPABASE_SERVICE_ROLE_KEY=  (Supabase Dashboard → Project Settings → API → service_role key — NE JAMAIS exposer côté client)
